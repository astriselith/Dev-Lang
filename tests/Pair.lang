
class Pair<First, Second> {
	var first: First;
	var second: Second;

	fun Pair(first: First, second: Second) {
		this.first = first;
		this.second = second;
	}

	fun getFirst(): First {
		return this.first;
	}

	fun getSecond(): Second {
		return this.second;
	}

	fun setFirst(value: First) {
		this.first = value;
	}

	fun setSecond(value: Second) {
		this.second = value;
	}

	fun swap(): Pair<Second, First> {
		return Pair<Second, First>(this.second, this.first);
	}

	fun toString(): String {
		return "(" + this.first.toString() + ", " + this.second.toString() + ")";
	}
}